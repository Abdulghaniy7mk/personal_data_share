# /etc/ai-os/agent.env
# API keys for Aegis OS AI planner
# Install: sudo cp agent.env /etc/ai-os/agent.env
#          sudo chmod 600 /etc/ai-os/agent.env
#          sudo chown root:ai-agent /etc/ai-os/agent.env
#
# Only fill in the key for the backend you chose in config/active.yaml
# Leave others blank — unused keys are ignored

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (ChatGPT) — https://platform.openai.com
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (free tier available) — https://console.groq.com
GROQ_API_KEY=

# OpenRouter (access 100+ models) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
