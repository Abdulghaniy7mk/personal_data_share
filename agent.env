# /etc/ai-os/agent.env
# Fill in only the key for your chosen backend
# chmod 600 this file after editing

# FREE TIER PROVIDERS (no credit card needed)
SAMBANOVA_API_KEY=        # https://cloud.sambanova.ai/apis
GROQ_API_KEY=             # https://console.groq.com/keys
CEREBRAS_API_KEY=         # https://cloud.cerebras.ai
GEMINI_API_KEY=           # https://aistudio.google.com/apikey
COHERE_API_KEY=           # https://dashboard.cohere.com/api-keys
MISTRAL_API_KEY=          # https://console.mistral.ai/api-keys
TOGETHER_API_KEY=         # https://api.together.ai/settings/api-keys
FIREWORKS_API_KEY=        # https://fireworks.ai/account/api-keys
OPENROUTER_API_KEY=       # https://openrouter.ai/keys
HF_API_KEY=               # https://huggingface.co/settings/tokens

# PAID PROVIDERS
ANTHROPIC_API_KEY=        # https://console.anthropic.com
OPENAI_API_KEY=           # https://platform.openai.com/api-keys
DEEPSEEK_API_KEY=         # https://platform.deepseek.com
XAI_API_KEY=              # https://console.x.ai
PERPLEXITY_API_KEY=       # https://www.perplexity.ai/settings/api
